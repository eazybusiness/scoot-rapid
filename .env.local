# Local Development Environment for ScootRapid
FLASK_APP=wsgi.py
FLASK_ENV=development

# Security
SECRET_KEY=dev-secret-key-change-in-production

# Database (Docker)
DB_NAME=scoot_rapid
DB_USER=scooter_user
DB_PASSWORD=scooter_pass
DB_HOST=localhost
DB_PORT=3306

# Pricing
BASE_PRICE_PER_MINUTE=0.30
START_FEE=1.50

# Limits
MAX_RENTAL_TIME_HOURS=12
